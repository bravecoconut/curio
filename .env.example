# CURIO environment configuration
# Copy this file to .env and fill in your values.

# OpenAI-compatible LLM API (used for topic selection, captions, research, image prompts)
BASE_URL=https://your-llm-provider.example.com
API_KEY=your_api_key_here
RESONNING_MODEL=your_reasoning_model_name

# Hugging Face token (used for FLUX.1-schnell image generation)
HF_TOKEN=your_huggingface_token_here
