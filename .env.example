# CURIO environment configuration
# Copy this file to .env and fill in your values.

# OpenAI-compatible LLM API (used for topic selection, captions, research, image prompts)
BASE_URL=https://your-llm-provider.example.com # don't include /v1
API_KEY=your_api_key_here
RESONNING_MODEL=your_reasoning_model_name

# Self-hosted image generation API endpoint (see documentations/13-image-generation-api.md)
IMAGE_MODEL_BASE_URL=http://localhost:5000/generate
